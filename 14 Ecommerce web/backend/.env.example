# ============================================================
# Backend Environment Variables
# Copy this file, rename to .env for local dev
# Set these as Environment Variables in Render Dashboard
# ============================================================

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/ecommerce-mini?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here
PORT=18451

EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Set this to your Vercel frontend URL after deploying frontend
FRONTEND_URL=https://your-app-name.vercel.app
